{
  "manifest_version": 3,
  "name": "CommentGuard",
  "version": "3.0",
  "description": "Real-time toxic comment filter with multi-label detection. Blurs toxic, threatening, hateful, and obscene comments across YouTube, Reddit, Twitter/X, and more.",

  "permissions": ["storage", "activeTab"],

  "host_permissions": [
    "https://www.youtube.com/*",
    "https://www.reddit.com/*",
    "https://news.ycombinator.com/*",
    "https://x.com/*",
    "https://twitter.com/*",
    "https://discord.com/*",
    "https://www.twitch.tv/*",
    "https://www.facebook.com/*",
    "https://www.instagram.com/*",
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "https://*/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://www.reddit.com/*",
        "https://news.ycombinator.com/*",
        "https://x.com/*",
        "https://twitter.com/*",
        "https://discord.com/*",
        "https://www.twitch.tv/*",
        "https://www.facebook.com/*",
        "https://www.instagram.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "CommentGuard — Toxic Comment Filter"
  },

  "icons": {
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  }
}
