# CommentGuard — Environment Configuration
# Copy this file to .env and adjust values as needed.

# Model type: "classical" (TF-IDF + LogReg) or "transformer" (toxic-bert)
MODEL_TYPE=classical

# Default toxicity threshold (0.0 – 1.0)
# Lower = stricter moderation, Higher = more lenient
THRESHOLD=0.5

# Environment label
ENV=development
